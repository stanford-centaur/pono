;; Test encoding of urgent condition (prop holds with urgent and not otherwise)
;;
(set-logic QF_LRA)

(declare-fun x__AT0 () Real)
(declare-fun x__AT1 () Real)
(declare-fun loc__AT0 () Bool)
(declare-fun loc__AT1 () Bool)

(define-fun .def_0 () Real (! x__AT0 :nextclock x__AT1))
(define-fun .def_2 () Real (! loc__AT0 :next loc__AT1))

;; Initial state
(define-fun .def_3 () Bool (! loc__AT0 :init true))

;; Transitions
(define-fun .def_18 () Bool (! (and

  (=> loc__AT0 (and
    (= x__AT1 0.0)
    (not loc__AT1)
    )
  )

  (=> (not loc__AT0) (and
    (= x__AT1 0.0)
    loc__AT1
    )
  )
) :trans true))

;; urgent
(define-fun .def_urgent () Bool (! true :urgent true))

(define-fun .def_19 () Bool (! (=> loc__AT0 (= 0.0 x__AT0) ) :invar-property 0))

(assert true)
